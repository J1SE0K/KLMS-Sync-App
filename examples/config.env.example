KLMS_DASHBOARD_URL="https://klms.kaist.ac.kr/my/"
KLMS_LOGIN_URL="https://klms.kaist.ac.kr/my/"
# Copy this file to config.env for local use. Do not commit config.env.
# Optional: override python3 when /usr/bin/python3 is the Xcode shim.
# KLMS_PYTHON_BIN="/absolute/path/to/python3"
# KLMS_PYTHONPATH_DIR="/absolute/path/to/runtime/python-packages"
# Optional: point this at a shared overrides file if the LaunchAgent install runs from a copied directory.
# OVERRIDES_JSON_PATH="/absolute/path/to/manual_assignment_overrides.json"
SAFARI_WAIT_SECONDS="6"
# Keep KLMS page fetch/download/login-assist Safari windows minimized.
KLMS_SAFARI_BACKGROUND_WINDOW_ENABLED="1"
SYNC_MODE="auto"
SYNC_MINIMAL_EXPLORATION_ENABLED="1"
SYNC_SKIP_UNCHANGED_CALENDAR_REMINDERS="1"
SYNC_COMMAND_TIMING_ENABLED="1"
SYNC_COMMAND_TIMING_MIN_DURATION_MS="0"
FILE_REFRESH_MODE="auto"
FILE_MINIMAL_EXPLORATION_ENABLED="1"
FILE_PRIMARY_BOARD_ALWAYS_FETCH_ONLY="1"
FILE_KEEP_FRESH_DOWNLOADS="0"
# Download staging stays under runtime/tmp/files/downloads by default, so
# ~/Downloads is not used. Override these only if you explicitly want a visible inbox.
# FILE_DOWNLOAD_WORK_ROOT="/absolute/path/to/download-work"
# FILE_NEW_FILES_ROOT="/absolute/path/to/KLMS New Files"
# FILE_QUARANTINE_ROOT="/absolute/path/to/KLMS Quarantine"
FILE_PRESERVE_DOWNLOAD_ARCHIVE="0"
# 1 keeps the current <course>/<bucket>/<week>/<filename> layout.
# 0 flattens week/source folders to <course>/<bucket>/<filename>.
FILE_WEEKLY_FOLDERS_ENABLED="1"
# Keep a JSON recovery log before pruning files outside the current manifest.
FILE_PRUNE_BACKUP_ENABLED="1"
FILE_PRUNE_BACKUP_KEEP="20"
FETCH_MIN_WAIT_SECONDS="1.5"
FETCH_STABLE_POLLS="2"
FETCH_COMPLETE_REUSE_SECONDS="3600"
FETCH_AUTO_FULL_MIN_COVERAGE="0.2"
FETCH_AUTO_REQUIRE_LAST_FULL="0"
FETCH_AUTO_FULL_ON_TTL_EXPIRE="0"
FILE_DOWNLOAD_TIMEOUT_SECONDS="180"
NOTICE_NATIVE_NOTE_TIMEOUT_SECONDS="420"
NOTICE_NATIVE_NOTE_TIMEOUT_GRACE_SECONDS="3"
NOTICE_NATIVE_STABLE_NOOP_SKIP="1"
NOTICE_NATIVE_ALWAYS_CAPTURE_STATE="1"
NOTICE_NATIVE_DEFER_STATE_ONLY_RENDER="0"
# Keep notice category/course/notice-title headings as real Notes headings.
# The primary rendered note finishes with only the top-level notice categories collapsed;
# KLMS 확인한 공지는 always re-renders with course headings collapsed.
NOTICE_COLLAPSE_SECTIONS="1"
NOTICE_COLLAPSE_COURSES="0"
NOTICE_COLLAPSE_NOTICE_ITEMS="0"
NOTICE_STYLE_NOTICE_ITEMS_AS_HEADINGS="1"
NOTICE_NATIVE_ENABLE_BATCH_CHECKLIST_FORMAT="1"
SYNC_FULL_TTL_SECONDS="259200"
SYNC_COURSE_PAGE_STALE_SECONDS="43200"
SYNC_ALL_WEEK_COURSE_PAGE_STALE_SECONDS="43200"
SYNC_DETAIL_QUICK_LIMIT="0"
SYNC_DETAIL_STALE_SECONDS="21600"
SYNC_SUPPLEMENTAL_QUICK_LIMIT="0"
SYNC_SUPPLEMENTAL_STALE_SECONDS="43200"
SYNC_SECONDARY_SUPPLEMENTAL_QUICK_LIMIT="0"
SYNC_SECONDARY_SUPPLEMENTAL_STALE_SECONDS="86400"
SYNC_SUPPLEMENTAL_DETAIL_QUICK_LIMIT="0"
SYNC_SUPPLEMENTAL_DETAIL_PINNED_QUICK_LIMIT="0"
SYNC_SUPPLEMENTAL_DETAIL_STALE_SECONDS="21600"
SYNC_SUPPLEMENTAL_DETAIL_INCLUDE_NON_RELEVANT_PRIMARY="0"
SYNC_ALWAYS_FETCH_MIN_INTERVAL_SECONDS="1800"
FILE_FULL_TTL_SECONDS="259200"
FILE_COURSE_PAGE_STALE_SECONDS="43200"
FILE_ALL_WEEK_COURSE_PAGE_STALE_SECONDS="43200"
FILE_SEED_QUICK_LIMIT="0"
FILE_SEED_STALE_SECONDS="43200"
# When the file seed URL list is unchanged and course_files already matches the manifest,
# reuse seed detail pages longer and let timestamp index pages catch replacements.
FILE_TIMESTAMP_GATED_SEED_REFRESH_ENABLED="1"
FILE_SEED_UNCHANGED_COURSE_STALE_SECONDS="259200"
# Prevent repeated manual/full runs from re-fetching every file seed page.
FILE_ALWAYS_FETCH_MIN_INTERVAL_SECONDS="21600"
FILE_NESTED_QUICK_LIMIT="0"
FILE_NESTED_STALE_SECONDS="86400"
FILE_NESTED2_QUICK_LIMIT="0"
FILE_NESTED2_STALE_SECONDS="86400"
FILE_NESTED_BACKGROUND_QUICK_LIMIT="0"
FILE_NESTED2_BACKGROUND_QUICK_LIMIT="0"
FETCH_CACHE_STATE_PATH=""
KLMS_LOGIN_FAST_TAB_CHECK_ENABLED="1"
# Reuse a recent successful login preflight to avoid a 2-3s dashboard fetch.
KLMS_LOGIN_STATUS_REUSE_SECONDS="900"
# Set this to 1 to advance Safari to the SSO approval screen and print the
# 2-digit number when the KLMS session expires.
KLMS_LOGIN_ASSIST_ENABLED="0"
# Run login assist before the slower dashboard preflight when tab state is
# unknown, so the 2-digit number appears as soon as Safari reaches SSO.
KLMS_LOGIN_ASSIST_EARLY_ENABLED="1"
# Default: scrape the 2-digit number from Safari and wait for phone approval.
# Use "kaikey-auto" only when this Mac is registered as the MFA device.
KLMS_LOGIN_ASSIST_MODE="manual-digits"
# Set this to 1 for LaunchAgent/Codex runs that do not have an interactive TTY.
KLMS_LOGIN_ASSIST_ALLOW_NONINTERACTIVE="0"
KLMS_LOGIN_ASSIST_NOTIFY_DIGITS_ENABLED="1"
# Required for login assist unless a registered Kaikey state file provides it.
# KLMS_SSO_LOGIN_ID="your-kaist-id"
# Legacy alias for login assist; prefer KLMS_LOGIN_ASSIST_ENABLED.
KAIKEY_LOGIN_ASSIST_ENABLED="0"
KAIKEY_AUTO_LOGIN_ENABLED="0"
# Legacy auto-approve toggle. Prefer KLMS_LOGIN_ASSIST_MODE="kaikey-auto".
KAIKEY_AUTO_APPROVE_ENABLED="0"
KAIKEY_MANUAL_APPROVAL_TIMEOUT_SECONDS="300"
KAIKEY_AUTO_LOGIN_POLL_SECONDS="0.2"
KAIKEY_SAFARI_STEP_TIMEOUT_SECONDS="12"
KAIKEY_SAFARI_STEP_POLL_MS="75"
KLMS_LOGIN_ASSIST_TWOFACTOR_REFRESH_SECONDS="150"
# The Kaikey state file is sensitive and must never be committed.
KAIKEY_STATE_PATH="$HOME/Library/Application Support/KLMSNotesSync/kaikey_state.json"
# KAIKEY_NODE_BIN="/opt/homebrew/bin/node"
KAIKEY_AUTO_LOGIN_TIMEOUT_SECONDS="90"
SYNC_INTERVAL_SECONDS="21600"
MIN_IDLE_SECONDS="600"
KLMS_LAUNCHD_LABEL="com.local.klms-notes-sync"
KLMS_AUTO_SYNC_ENABLED="1"
LOGIN_PROMPT_COOLDOWN_SECONDS="3600"
LOGIN_PROMPT_OPEN_SAFARI="0"
NOTES_SYNC_ENABLED="0"
EXAM_CALENDAR_SYNC_ENABLED="1"
EXAM_CALENDAR_NAME="시험"
HELP_DESK_CALENDAR_SYNC_ENABLED="1"
HELP_DESK_CALENDAR_NAME="기타"
# Deprecated fallback. Keep 0 unless Swift Calendar sync is unavailable and
# you explicitly want to try the older JXA Calendar path.
CALENDAR_SYNC_APPLESCRIPT_FALLBACK="0"
CALENDAR_EVENT_DURATION_MINUTES="15"
CALENDAR_LOOKBACK_DAYS="365"
REMINDERS_SYNC_ENABLED="1"
NOTICE_SUMMARY_ENABLED="1"
NOTICE_SHARED_FALLBACK_MAX_AGE_SECONDS="43200"
NOTICE_NOTE_NAME="KLMS 공지"
NOTICE_ARCHIVE_NOTE_NAME="KLMS 확인한 공지"
NOTICE_AUTO_IMPORTANT_KEYWORDS_APPLY="0"
REMINDERS_LIST_NAME="KLMS 과제"
REMINDERS_ISSUE_LIST_NAME="KLMS 확인 필요"
REMINDER_STAGE_ALERTS_ENABLED="0"
REMINDER_CLEAN_DISABLED_STAGE_ALERTS="0"
REMINDER_RECREATE_STAGE_ALERT_LIST="1"
REMINDER_ALERT_LIST_NAME="KLMS 알림"
REMINDER_DEVICE_ALERTS_ENABLED="0"
REMINDER_DEVICE_ALERT_MODE="adaptive"
MACOS_REMINDER_NOTIFICATIONS_ENABLED="0"
COMPLETED_REMINDER_RETENTION_DAYS="0"

# Manual assignment workbench. This is not part of automatic KLMS sync.
# Run ./process_klms_assignments.sh when you want local assignment prep files.
ASSIGNMENT_PROCESSOR_OUTPUT_ROOT="$SCRIPT_DIR/runtime/assignment_work"
ASSIGNMENT_GENERATION_PROVIDER="codex"
ASSIGNMENT_CODEX_BIN="/opt/homebrew/bin/codex"
ASSIGNMENT_CODEX_TIMEOUT_SECONDS="300"
ASSIGNMENT_MAX_LINKED_MATERIALS="8"
